class Solution {
public:
    string mergeAlternately(string word1, string word2) {
       int n=size(word1)+size(word2);
       string word3;
       int i=0,j=0;
        while(i<size(word1) && j<size(word2))
        {
            word3.push_back(word1[i]);
                i++;
            word3.push_back(word2[j]);
                j++;
        }
        while(i<size(word1))
        {
            word3.push_back(word1[i]);
                i++;
        }
        while(j<size(word2))
        {
            word3.push_back(word2[j]);
                j++;
        }
        return word3;
    }
};
