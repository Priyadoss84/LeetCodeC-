class Solution {
public:
    bool uniqueOccurrences(vector<int>& arr) {
        if(arr.size()<2)
            return true;
        unordered_map<int,int> mp;
        for (int x:arr)
        {
            mp[x]++;
        }
        unordered_set<int> s;
        for(auto it:mp)
        {
            if(s.find(it.second)!=s.end())
                return false;
            s.insert(it.second);
        }
        return true;
    }
};
