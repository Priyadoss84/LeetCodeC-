class Solution {
public:
    vector<int> productExceptSelf(vector<int>& nums) {
        vector<int> arr;
        int n=nums.size();
        for(int i=0;i<n;i++)
        {
            int prd=1;
            for(int j=0;j<n;j++)
            {
                if(i!=j)
                    prd=prd*nums[j];
            }
            arr.push_back(prd);
        }
        return arr;
    }
};
