class Solution {
public:
    vector<bool> kidsWithCandies(vector<int>& candies, int extraCandies) {
        int n=size(candies); 
        int greatest=0; 
        vector<bool> output;
        for(int i=0;i<n;i++)
        {
            greatest=max(greatest,candies[i]);
        }
        for(int i=0;i<n;i++)
        {
            if(greatest <= (candies[i]+extraCandies))
                output.push_back(true);
            else
                output.push_back(false);
        }
        return  output;
    }
};
