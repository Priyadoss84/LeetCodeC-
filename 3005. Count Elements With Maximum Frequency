class Solution {
public:
    int maxFrequencyElements(vector<int>& nums) {
        if(nums.size()==1)
            return 1;
        if(nums.size()==0)
            return 0;
        unordered_map<int,int> mp;
        for (int x:nums)
            mp[x]++;

        int max_freq=0;
        for(auto it:mp)
        {
            max_freq=max(max_freq,it.second);
        }
        int count=0;
        for(auto it:mp)
        {
            if(it.second==max_freq)
                count+=it.second;
        }
        return count;
    }
};
