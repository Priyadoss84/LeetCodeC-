class Solution {
public:
    bool isAnagram(string s, string t) {
        if(s.size()!=t.size())
            return false;
        vector<int> count(26,0);
        for (char c:s)
            count[c-'a']++;
        for (char c:t)
        {
            count[c-'a']--;
            if(count[c-'a']<0)
                return false;
        }
        return true;
    }
};


//Optimized method:

class Solution {
public:
    bool isAnagram(string s, string t) {
        unordered_map<char,int> mp;
        if(s.size()!=t.size())
            return false;
        for (char x:s)
            mp[x]++;
        for (char y:t)
        {
            if(mp[y]==0)
                return false;
            mp[y]--;
        }
        return true;
    }
};
